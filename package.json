{
  "name": "leetcode-admin-dashboard",
  "version": "1.0.0",
  "description": "Admin dashboard to track college students' LeetCode progress and practice assignments.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:env": "node --env-file=.env src/server.js",
    "dev": "node --watch src/server.js",
    "refresh": "node src/refresh-cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.3.0"
  }
}
